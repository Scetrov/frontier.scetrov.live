                    "application/json"
                ],
                "tags": [
                    "game"
                ],
                "summary": "list all the jumps for the current user",
                "responses": {
                    "200": {
                        "description": "jumps with some metadata",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/v2.paginatedResponse"
